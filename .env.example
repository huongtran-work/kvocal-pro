# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Replit provides DATABASE_URL automatically)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ─── Demo Authentication ──────────────────────────────────────────────────────
# Server-side: password validated in API route
DEMO_PASSWORD="your-demo-password"
# Client-side: used to auto-fill the login form (NEXT_PUBLIC_ prefix required)
NEXT_PUBLIC_DEMO_PASSWORD="your-demo-password"

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"
